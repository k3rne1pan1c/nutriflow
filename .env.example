# Supabase (from project Settings → API)
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
# Optional — defaults to gemini-flash-latest (same alias as AI Studio curl examples)
# GEMINI_MODEL=gemini-flash-latest

# Set to true during daily dev to skip API calls (zero cost)
AI_MOCK=true

# Log full Gemini JSON + diff stats in server terminal; returns debug in API responses
AI_DEBUG=true

# Dev auth — instant email sign-in (local only, never enable in production)
DEV_AUTH=true
DEV_AUTH_PASSWORD=nutriflow-dev

# Admin access: set profiles.is_admin = true in Supabase (see migration 20260704300000_profile_is_admin.sql)
